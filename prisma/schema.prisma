generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id    Int      @id @default(autoincrement())
  user_email String   @unique(map: "User_email_key")
  user_name  String?
  createdAt  DateTime @default(now())
  user_pass  String
}

model addons {
  addon_id    Int     @id @default(autoincrement())
  addon_name  String
  addon_desc  String
  addon_price Decimal @db.Decimal(2, 0)
  addon_avail Boolean
}

model bookings {
  booking_id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_price     Decimal  @db.Decimal(10, 2)
  created_at        DateTime @default(now()) @db.Timestamp(6)
  pax_total         Int
  pax_my_adult      Int
  pax_my_kid        Int
  pax_my_senior     Int
  pax_my_oku        Int
  pax_non_my_adult  Int
  pax_non_my_kid    Int
  pax_non_my_senior Int
  pax_non_my_oku    Int
  pic_name          String
  pic_email         String
  pic_hp            String
  org_address       String
  org_name          String
  org_state         String
  org_type          String
  quotation_id      String?  @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slot_id           String
  package_id        String   @unique
  slots             slots    @relation(fields: [slot_id], references: [slot_id], onDelete: NoAction, onUpdate: NoAction, map: "slot_fkey")
}

model foods {
  food_id    Int     @id @default(autoincrement())
  food_name  String
  food_price Decimal @db.Decimal(2, 0)
}

model packages {
  package_id           String  @id @default(dbgenerated("gen_random_uuid()"))
  package_name         String
  package_availability Boolean
  package_note         String?
  price_my_adult       Decimal @db.Decimal(2, 0)
  price_my_kid         Decimal @db.Decimal(2, 0)
  price_my_senior      Decimal @db.Decimal(2, 0)
  price_my_oku         Decimal @db.Decimal(2, 0)
  price_non_my_adult   Decimal @db.Decimal(2, 0)
  price_non_my_kid     Decimal @db.Decimal(2, 0)
  price_non_my_senior  Decimal @db.Decimal(2, 0)
  price_non_my_oku     Decimal @db.Decimal(2, 0)
}

model slots {
  slot_id       String     @id
  slot_name     String
  slot_start    DateTime   @db.Time(6)
  slot_end      DateTime   @db.Time(6)
  slot_capacity Int
  bookings      bookings[]
}
