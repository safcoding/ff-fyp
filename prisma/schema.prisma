generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  createdAt     DateTime  @default(now())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  updatedAt     DateTime  @updatedAt
  banExpires    DateTime?
  banReason     String?
  banned        Boolean?  @default(false)
  role          String?
  accounts      Account[]
  sessions      Session[]

  @@map("user")
}

model addons {
  addon_id       Int              @id @default(autoincrement())
  addon_name     String
  addon_desc     String
  addon_price    Decimal          @db.Decimal(6, 2)
  addon_avail    Boolean
  booking_addons booking_addons[]
}

model bookings {
  booking_id           String             @id @default(uuid())
  booking_price        Decimal            @db.Decimal(10, 2)
  created_at           DateTime           @default(now()) @db.Timestamp(6)
  pax_total            Int
  pic_name             String
  pic_email            String
  pic_hp               String
  org_address          String
  org_name             String
  slot_id              String
  booking_date         DateTime?          @db.Date
  booking_status       booking_status?    @default(PENDING)
  discount_id          String?
  org_state            states
  org_type             org_categories
  event_name           String?
  assigned_guide_count Int?
  booking_addons       booking_addons[]
  booking_foods        booking_foods[]
  booking_packages     booking_packages[]
  discounts            discounts?         @relation(fields: [discount_id], references: [discount_id], onDelete: Restrict, map: "discount_id_fkey")
  slots                slots              @relation(fields: [slot_id], references: [slot_id], map: "slot_fkey")

  @@index([booking_status])
  @@index([created_at])
  @@index([booking_date])
}

model foods {
  food_id       Int             @id @default(autoincrement())
  food_name     String
  food_price    Decimal         @db.Decimal(6, 2)
  booking_foods booking_foods[]
}

model packages {
  package_id           String               @id @default(uuid())
  package_name         String
  package_availability Boolean
  package_note         String?
  price_my_adult       Decimal              @db.Decimal(3, 0)
  price_my_kid         Decimal              @db.Decimal(3, 0)
  price_my_senior      Decimal              @db.Decimal(3, 0)
  price_my_oku         Decimal              @db.Decimal(3, 0)
  price_non_my_adult   Decimal              @db.Decimal(3, 0)
  price_non_my_kid     Decimal              @db.Decimal(3, 0)
  price_non_my_senior  Decimal              @db.Decimal(3, 0)
  price_non_my_oku     Decimal              @db.Decimal(3, 0)
  package_features     String[]             @default([])
  minimum_pax          Int?
  booking_packages     booking_packages[]
  package_activities   package_activities[]
}

model slots {
  slot_id        String           @id
  slot_name      String
  slot_start     DateTime         @db.Time(6)
  slot_end       DateTime         @db.Time(6)
  slot_capacity  Int
  slot_type      slot_types       @default(UNGUIDED)
  booking_blocks booking_blocks[]
  bookings       bookings[]
  slot_schedules slot_schedules[]
}

model booking_addons {
  booking_id     String
  addon_id       Int
  addon_quantity Int
  id             Int      @id @default(autoincrement())
  subtotal       Decimal? @db.Decimal(10, 2)
  addons         addons   @relation(fields: [addon_id], references: [addon_id], map: "addon_id_fkey")
  bookings       bookings @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade, map: "booking_id_fkey")
}

model booking_foods {
  booking_id    String
  food_id       Int
  food_quantity Int
  id            Int      @id @default(autoincrement())
  subtotal      Decimal? @db.Decimal(10, 2)
  bookings      bookings @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade, map: "booking_id_fkey")
  foods         foods    @relation(fields: [food_id], references: [food_id], map: "food_id_fkey")
}

model booking_packages {
  booking_id         String
  package_id         String
  pax_my_adult       Int?
  pax_my_kid         Int?
  pax_my_senior      Int?
  pax_my_oku         Int?
  pax_non_my_adult   Int?
  pax_non_my_kid     Int?
  pax_non_my_senior  Int?
  pax_non_my_oku     Int?
  subtotal           Decimal?    @db.Decimal(10, 2)
  id                 Int         @id @default(autoincrement())
  selected_activity  Int?
  package_activities activities? @relation(fields: [selected_activity], references: [activity_id], onDelete: NoAction, onUpdate: NoAction, map: "activity_name_fkey")
  bookings           bookings    @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade, map: "booking_id_fkey")
  packages           packages    @relation(fields: [package_id], references: [package_id], map: "package_id_fkey")
}

model discounts {
  discount_id     String         @id
  discount_type   discount_types
  discount_amount Decimal        @db.Decimal(6, 2)
  bookings        bookings[]
}

model package_activities {
  id          Int         @id(map: "package_activities_pkey1") @default(autoincrement())
  activity_id Int?
  package_id  String?
  activities  activities? @relation(fields: [activity_id], references: [activity_id], onDelete: NoAction, onUpdate: NoAction, map: "activity_id_fkey")
  packages    packages?   @relation(fields: [package_id], references: [package_id], onDelete: NoAction, onUpdate: NoAction, map: "package_id_fkey")
}

model activities {
  activity_name      String
  activity_desc      String?
  is_active          Boolean?
  activity_id        Int                  @id @default(autoincrement())
  booking_packages   booking_packages[]
  package_activities package_activities[]
}

model slot_schedules {
  id         Int      @id @default(autoincrement())
  slot_id    String
  day_type   day_type
  start_time DateTime @db.Time(6)
  end_time   DateTime @db.Time(6)
  slots      slots    @relation(fields: [slot_id], references: [slot_id], onDelete: Cascade, map: "slot_id_fkey")

  @@unique([slot_id, day_type])
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model booking_blocks {
  id         Int      @id @default(autoincrement())
  block_date DateTime @db.Date
  slot_id    String?
  reason     String?
  slots      slots?   @relation(fields: [slot_id], references: [slot_id], onDelete: Cascade, onUpdate: NoAction, map: "slot_id_fkey")
}

model global_settings {
  id               Int     @id @default(autoincrement())
  min_lead_days    Int?
  company_name     String?
  company_address  String?
  company_phone    String?
  company_email    String?
  sst_registration String?
}

enum booking_status {
  PENDING
  APPROVED
  POSTPONED
  CANCELLED
}

enum discount_types {
  PERCENTAGE
  FLAT
}

enum org_categories {
  CORPORATE
  GOVERNMENT
  UNIVERSITY_COLLEGE   @map("UNIVERSITY/COLLEGE")
  INTERNATIONAL_SCHOOL @map("INTERNATIONAL SCHOOL")
  SECONDARY_SCHOOL     @map("SECONDARY SCHOOL")
  PRIMARY_SCHOOL       @map("PRIMARY SCHOOL")
  KINDERGARTEN
  TRAVEL_AGENCY        @map("TRAVEL AGENCY")
  PERSONAL_GROUP       @map("PERSONAL GROUP")
}

enum states {
  JOHOR
  MELAKA
  NEGERI_SEMBILAN @map("NEGERI SEMBILAN")
  SELANGOR
  KUALA_LUMPUR    @map("KUALA LUMPUR")
  PUTRAJAYA
  PERAK
  KEDAH
  PERLIS
  PULAU_PINANG    @map("PULAU PINANG")
  TERENGGANU
  PAHANG
  SABAH
  SARAWAK
  LABUAN
}

enum slot_types {
  GUIDED
  UNGUIDED
}

enum day_type {
  WEEKEND
  WEEKDAY
}
