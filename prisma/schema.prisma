generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id    Int      @id @default(autoincrement())
  user_email String   @unique(map: "User_email_key")
  user_name  String?
  createdAt  DateTime @default(now())
  user_pass  String
}

model addons {
  addon_id       Int              @id @default(autoincrement())
  addon_name     String
  addon_desc     String
  addon_price    Decimal          @db.Decimal(6, 2)
  addon_avail    Boolean
  booking_addons booking_addons[]
}

model bookings {
  booking_id                                   String             @id @default(uuid())
  booking_price                                Decimal            @db.Decimal(10, 2)
  created_at                                   DateTime           @default(now()) @db.Timestamp(6)
  pax_total                                    Int
  pic_name                                     String
  pic_email                                    String
  pic_hp                                       String
  org_address                                  String
  org_name                                     String
  org_state                                    states
  org_type                                     org_categories
  quotation_id                                 String?
  slot_id                                      String
  booking_date                                 DateTime?          @db.Date
  booking_status                               booking_status?    @default(PENDING)
  discount_id                                  String?
  booking_addons                               booking_addons[]
  booking_foods                                booking_foods[]
  booking_packages                             booking_packages[]
  discounts                                    discounts?         @relation(fields: [discount_id], references: [discount_id], onDelete: NoAction, onUpdate: NoAction, map: "discount_id_fkey")
  quotations_bookings_quotation_idToquotations quotations?        @relation("bookings_quotation_idToquotations", fields: [quotation_id], references: [quotation_id], onDelete: NoAction, onUpdate: NoAction, map: "quotation_id_fkey")
  slots                                        slots              @relation(fields: [slot_id], references: [slot_id], onDelete: NoAction, onUpdate: NoAction, map: "slot_fkey")
  quotations                                   quotations[]
}

model foods {
  food_id       Int             @id @default(autoincrement())
  food_name     String
  food_price    Decimal         @db.Decimal(6, 2)
  booking_foods booking_foods[]
}

model packages {
  package_id           String             @id @default(uuid())
  package_name         String
  package_availability Boolean
  package_note         String?
  price_my_adult       Decimal            @db.Decimal(3, 0)
  price_my_kid         Decimal            @db.Decimal(3, 0)
  price_my_senior      Decimal            @db.Decimal(3, 0)
  price_my_oku         Decimal            @db.Decimal(3, 0)
  price_non_my_adult   Decimal            @db.Decimal(3, 0)
  price_non_my_kid     Decimal            @db.Decimal(3, 0)
  price_non_my_senior  Decimal            @db.Decimal(3, 0)
  price_non_my_oku     Decimal            @db.Decimal(3, 0)
  package_features     String[]           @default([])
  minimum_pax          Int?
  booking_packages     booking_packages[]
}

model slots {
  slot_id       String     @id
  slot_name     String
  slot_start    DateTime   @db.Time(6)
  slot_end      DateTime   @db.Time(6)
  slot_capacity Int
  bookings      bookings[]
}

model booking_addons {
  booking_id     String
  addon_id       Int
  addon_quantity Int
  id             Int      @id @default(autoincrement())
  subtotal       Decimal? @db.Decimal(10, 2)
  addons         addons   @relation(fields: [addon_id], references: [addon_id], onDelete: NoAction, onUpdate: NoAction, map: "addon_id_fkey")
  bookings       bookings @relation(fields: [booking_id], references: [booking_id], onDelete: NoAction, onUpdate: NoAction, map: "booking_id_fkey")
}

model booking_foods {
  booking_id    String  
  food_id       Int
  food_quantity Int
  id            Int      @id @default(autoincrement())
  subtotal      Decimal? @db.Decimal(10, 2)
  bookings      bookings @relation(fields: [booking_id], references: [booking_id], onDelete: NoAction, onUpdate: NoAction, map: "booking_id_fkey")
  foods         foods    @relation(fields: [food_id], references: [food_id], onDelete: NoAction, onUpdate: NoAction, map: "food_id_fkey")
}

model quotations {
  quotation_id                               String     @id
  booking_id                                 String?
  bookings_bookings_quotation_idToquotations bookings[] @relation("bookings_quotation_idToquotations")
  bookings                                   bookings?  @relation(fields: [booking_id], references: [booking_id], onDelete: NoAction, onUpdate: NoAction, map: "booking_fkey")
}

model booking_packages {
  booking_id        String
  package_id        String
  pax_my_adult      Int?
  pax_my_kid        Int?
  pax_my_senior     Int?
  pax_my_oku        Int?
  pax_non_my_adult  Int?
  pax_non_my_kid    Int?
  pax_non_my_senior Int?
  pax_non_my_oku    Int?
  subtotal          Decimal? @db.Decimal(10, 2)
  id                Int      @id @default(autoincrement())
  bookings          bookings @relation(fields: [booking_id], references: [booking_id], onDelete: NoAction, onUpdate: NoAction, map: "booking_id_fkey")
  packages          packages @relation(fields: [package_id], references: [package_id], onDelete: NoAction, onUpdate: NoAction, map: "package_id_fkey")
}

model discounts {
  discount_id     String         @id
  discount_type   discount_types
  discount_amount Decimal        @db.Decimal(6, 2)
  bookings        bookings[]
}

enum booking_status {
  PENDING
  APPROVED
  POSTPONED
  CANCELLED
}

enum discount_types {
  PERCENTAGE
  FLAT
}

enum org_categories {
  CORPORATE
  GOVERNMENT
  UNIVERSITY_COLLEGE   @map("UNIVERSITY/COLLEGE")
  INTERNATIONAL_SCHOOL @map("INTERNATIONAL SCHOOL")
  SECONDARY_SCHOOL     @map("SECONDARY SCHOOL")
  PRIMARY_SCHOOL       @map("PRIMARY SCHOOL")
  KINDERGARTEN
  TRAVEL_AGENCY        @map("TRAVEL AGENCY")
  PERSONAL_GROUP       @map("PERSONAL GROUP")
}

enum states {
  JOHOR
  MELAKA
  NEGERI_SEMBILAN @map("NEGERI SEMBILAN")
  SELANGOR
  KUALA_LUMPUR    @map("KUALA LUMPUR")
  PUTRAJAYA
  PERAK
  KEDAH
  PERLIS
  PULAU_PINANG    @map("PULAU PINANG")
  TERENGGANU
  PAHANG
  SABAH
  SARAWAK
  LABUAN
}
